{
  "name": "@resonance/app",
  "version": "0.1.2",
  "description": "Resonance — Privacy-preserving decentralized matching",
  "author": "Planetary Project <hello@planetary.earth>",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite --config vite.config.ts",
    "electron:build": "vite build && electron-builder",
    "start": "tsx src/server/start.ts",
    "test": "vitest run"
  },
  "build": {
    "appId": "earth.planetary.resonance",
    "productName": "Resonance",
    "electronVersion": "34.5.8",
    "directories": {
      "output": "dist-release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!node_modules"
    ],
    "asar": true,
    "npmRebuild": false,
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.social-networking"
    },
    "win": {
      "target": ["nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  },
  "dependencies": {
    "@resonance/core": "*",
    "@resonance/node": "*",
    "@resonance/relay": "*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.0",
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^3.2.0"
  }
}
