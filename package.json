{
  "name": "resonance",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "npm test --workspace=@resonance/core && npm test --workspace=@resonance/node && npm test --workspace=@resonance/relay",
    "eval": "npm run eval --workspace=@resonance/eval",
    "eval:quick": "npm run eval:quick --workspace=@resonance/eval",
    "resonance": "npm run resonance --workspace=@resonance/node --",
    "app": "npm run start --workspace=@resonance/app"
  }
}
